:host {
  --primary: #4f46e5;
  --bg: #f3f4f6;
  --card: #ffffff;
  --text-main: #111827;
  --text-muted: #6b7280;
  --accent: #fbbf24;
}

.app-container {
  min-height: 100vh;
  background-color: var(--bg);
  font-family: 'Inter', -apple-system, sans-serif;
  padding: 0 40px 40px;
}

/* Header */
.main-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25px 0;
}
.brand h1 { font-size: 1.5rem; margin: 0; display: inline; color: var(--text-main); }
.brand h1 small { color: var(--primary); font-size: 0.8rem; }
.status-dot { height: 10px; width: 10px; background: #10b981; border-radius: 50%; display: inline-block; margin-right: 5px; }

/* Grid Layout */
.dashboard-grid {
  display: grid;
  grid-template-columns: 420px 1fr;
  gap: 30px;
}

.panel-card {
  background: var(--card);
  border-radius: 20px;
  padding: 30px;
  box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
  border: 1px solid rgba(0,0,0,0.05);
}

/* Form Styling */
.section-label { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--text-muted); margin: 25px 0 15px; display: block; letter-spacing: 1px; }
.input-row { display: grid; grid-template-columns: 100px 1fr; gap: 15px; }
.field label { display: block; font-size: 0.8rem; margin-bottom: 8px; font-weight: 600; color: var(--text-muted); }
input { width: 100%; padding: 12px 15px; border: 1.5px solid #e5e7eb; border-radius: 10px; transition: 0.3s; font-size: 0.9rem; box-sizing: border-box;}
input:focus { border-color: var(--primary); outline: none; box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }

.marks-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; }
.m-field span { display: block; font-size: 0.7rem; font-weight: 800; margin-bottom: 5px; }

.btn-publish {
  width: 100%; margin-top: 30px; padding: 15px; border-radius: 12px;
  background: var(--primary); color: white; border: none; font-weight: 700; cursor: pointer; transition: 0.3s;
}
.btn-publish:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(79, 70, 229, 0.4); }

/* Result Panel */
.search-container { display: flex; gap: 10px; background: #f9fafb; padding: 8px; border-radius: 15px; margin-bottom: 30px; }
.search-container input { border: none; background: transparent; }
.btn-search { background: var(--text-main); color: white; padding: 10px 25px; border-radius: 10px; border: none; cursor: pointer; font-weight: 600; }

.viz-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px; }
.rank-badge { text-align: center; background: var(--accent); padding: 10px 20px; border-radius: 15px; }
.rank-badge small { display: block; font-size: 0.6rem; font-weight: 900; }
.rank-badge strong { font-size: 1.4rem; }

.stats-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
.stat-box { background: #f9fafb; padding: 20px; border-radius: 15px; text-align: center; }
.stat-box.accent { background: #eef2ff; border: 1px solid var(--primary); }
.stat-box label { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; }
.stat-box .value { font-size: 1.8rem; font-weight: 800; color: var(--text-main); }

/* Progress Bars */
.summary-item { display: grid; grid-template-columns: 100px 1fr 40px; align-items: center; gap: 15px; margin-bottom: 12px; }
.sub-name { font-size: 0.85rem; font-weight: 600; }
.progress-track { background: #e5e7eb; height: 8px; border-radius: 4px; overflow: hidden; }
.progress-fill { background: var(--primary); height: 100%; transition: 1s ease-out; }
.progress-fill.low { background: #ef4444; }
.sub-score { font-weight: 700; text-align: right; }

.empty-state { text-align: center; padding: 100px 0; color: var(--text-muted); }
.empty-icon { font-size: 3rem; margin-bottom: 15px; opacity: 0.5; }
