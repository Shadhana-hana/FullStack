import { Component, signal, inject } from '@angular/core';
import { CommonModule } from '@angular/common';
import { FormBuilder, Validators, ReactiveFormsModule, FormsModule } from '@angular/forms';
import { ResultService } from './result.service';
import { StudentResult } from './result.model';

@Component({
  selector: 'app-root',
  standalone: true,
  imports: [CommonModule, ReactiveFormsModule, FormsModule],
  templateUrl: './app.component.html',
  styleUrls: ['./app.component.css']
})
export class AppComponent {
  private fb = inject(FormBuilder);
  private resultService = inject(ResultService);

  adminForm = this.fb.group({
    rollNo: ['', [Validators.required]],
    name: ['', [Validators.required]],
    sub1: [0, [Validators.required, Validators.min(0), Validators.max(100)]],
    sub2: [0, [Validators.required, Validators.min(0), Validators.max(100)]],
    sub3: [0, [Validators.required, Validators.min(0), Validators.max(100)]],
    sub4: [0, [Validators.required, Validators.min(0), Validators.max(100)]],
    sub5: [0, [Validators.required, Validators.min(0), Validators.max(100)]],
    sub6: [0, [Validators.required, Validators.min(0), Validators.max(100)]]
  });

  searchRoll: string = '';
  foundResult = signal<StudentResult | undefined>(undefined);

  onPublish() {
    if (this.adminForm.valid) {
      const f = this.adminForm.value;
      const subjects = [
        { name: 'Mathematics', marks: f.sub1 ?? 0, max: 100 },
        { name: 'Physics', marks: f.sub2 ?? 0, max: 100 },
        { name: 'Chemistry', marks: f.sub3 ?? 0, max: 100 },
        { name: 'Biology', marks: f.sub4 ?? 0, max: 100 },
        { name: 'English', marks: f.sub5 ?? 0, max: 100 },
        { name: 'Computer Sc', marks: f.sub6 ?? 0, max: 100 }
      ];

      const total = subjects.reduce((sum, s) => sum + s.marks, 0);
      const avg = total / subjects.length;

      const newRecord: StudentResult = {
        rollNo: f.rollNo ?? '',
        name: f.name ?? '',
        class: '12th Grade',
        subjects: subjects,
        average: Number(avg.toFixed(2)),
        cgpa: Number((avg / 10).toFixed(2)) // Standard 10-point scale
      };

      this.resultService.addResult(newRecord);
      this.adminForm.reset({ sub1: 0, sub2: 0, sub3: 0, sub4: 0, sub5: 0, sub6: 0 });
      alert('Student Record Published!');
    }
  }

  onSearch() {
    this.foundResult.set(this.resultService.getResult(this.searchRoll));
  }
}

