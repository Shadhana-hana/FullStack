<div class="app-container">
  <!-- Top Navigation Bar -->
  <header class="main-header">
    <div class="brand">
      <span class="icon">🎓</span>
      <h1>EduScore <small>v2.0</small></h1>
    </div>
    <div class="user-action">
      <span class="status-dot"></span> System Live
    </div>
  </header>

  <main class="dashboard-grid">
    <!-- LEFT: Entry Panel -->
    <section class="panel-card admin-card">
      <div class="panel-header">
        <div class="title-group">
          <h2>Academic Entry</h2>
          <p>Fill student marks to generate report</p>
        </div>
      </div>

      <form [formGroup]="adminForm" (ngSubmit)="onPublish()" class="styled-form">
        <div class="input-row main-info">
          <div class="field">
            <label>Roll Number</label>
            <input formControlName="rollNo" placeholder="E.g. 24001">
          </div>
          <div class="field">
            <label>Student Name</label>
            <input formControlName="name" placeholder="Full Name">
          </div>
        </div>

        <label class="section-label">Subject Wise Performance</label>
        <div class="marks-grid">
          <div class="m-field"><span>MAT</span><input type="number" formControlName="sub1"></div>
          <div class="m-field"><span>PHY</span><input type="number" formControlName="sub2"></div>
          <div class="m-field"><span>CHE</span><input type="number" formControlName="sub3"></div>
          <div class="m-field"><span>BIO</span><input type="number" formControlName="sub4"></div>
          <div class="m-field"><span>ENG</span><input type="number" formControlName="sub5"></div>
          <div class="m-field"><span>CSC</span><input type="number" formControlName="sub6"></div>
        </div>

        <button type="submit" [disabled]="adminForm.invalid" class="btn-publish">
          <span>Publish Marksheet</span>
        </button>
      </form>
    </section>

    <!-- RIGHT: Insight Panel -->
    <section class="panel-card student-card">
      <div class="search-container">
        <input name="search" [(ngModel)]="searchRoll" placeholder="Enter Roll ID to generate report...">
        <button (click)="onSearch()" class="btn-search">Generate</button>
      </div>

      <!-- Result Visualizer -->
      <div *ngIf="foundResult() as res" class="result-viz animate-in">
        <div class="viz-header">
          <div class="student-info">
            <h3>{{ res.name }}</h3>
            <span class="id-badge">ID: {{ res.rollNo }}</span>
          </div>
          <div class="rank-badge">
            <small>GLOBAL RANK</small>
            <strong>#{{ res.rank }}</strong>
          </div>
        </div>

        <div class="stats-cards">
          <div class="stat-box">
            <label>Average</label>
            <div class="value">{{ res.average }}%</div>
          </div>
          <div class="stat-box accent">
            <label>CGPA</label>
            <div class="value">{{ res.cgpa }}</div>
          </div>
        </div>

        <div class="marks-summary">
          <div class="summary-item" *ngFor="let s of res.subjects">
            <span class="sub-name">{{ s.name }}</span>
            <div class="progress-track">
              <div class="progress-fill" [style.width.%]="s.marks" [class.low]="s.marks < 35"></div>
            </div>
            <span class="sub-score">{{ s.marks }}</span>
          </div>
        </div>
      </div>

      <!-- Empty State -->
      <div *ngIf="!foundResult()" class="empty-state">
        <div class="empty-icon">📊</div>
        <p>Awaiting Search Query</p>
        <small>Enter a student roll number to fetch real-time analytics.</small>
      </div>
    </section>
  </main>
</div>

